{
  "name": "gaugewright-web",
  "version": "0.2.0",
  "private": true,
  "license": "Apache-2.0",
  "type": "module",
  "description": "GaugeBench \u2014 the Solid 1.x projection-first island.",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "build:open": "vite build --config vite.open.config.ts",
    "build:embed": "vite build --config vite.embed.config.ts",
    "build:apps:open": "vite build --config vite.apps.open.config.ts",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "typecheck:open-client": "tsc --noEmit -p tsconfig.open-client.json",
    "typecheck:workbench-web": "tsc --noEmit -p tsconfig.workbench-web.json",
    "typecheck:workbench-ui": "tsc --noEmit -p tsconfig.workbench-ui.json",
    "typecheck:mobile-client": "tsc --noEmit -p tsconfig.mobile-client.json",
    "typecheck:embed-client": "tsc --noEmit -p tsconfig.embed-client.json",
    "typecheck:split": "npm run typecheck:open-client && npm run typecheck:workbench-web && npm run typecheck:workbench-ui && npm run typecheck:mobile-client && npm run typecheck:embed-client",
    "test": "vitest run",
    "e2e": "node e2e/run.mjs",
    "e2e:live": "GW_E2E_LIVE=1 node e2e/run.mjs"
  },
  "dependencies": {
    "@git-diff-view/file": "^0.1.5",
    "@git-diff-view/solid": "^0.1.5",
    "@tauri-apps/plugin-dialog": "^2.7.1",
    "qrcode-generator": "^2.0.4",
    "solid-js": "^1.9.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "playwright-bdd": "^9.0.0",
    "typescript": "^5.6.0",
    "vite": "^8.1.2",
    "vite-plugin-solid": "^2.11.12",
    "vitest": "^4.1.9"
  }
}
