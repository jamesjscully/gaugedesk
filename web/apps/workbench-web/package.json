{
  "name": "@gaugewright/workbench-web",
  "version": "0.0.0",
  "private": true,
  "license": "Apache-2.0",
  "type": "module",
  "description": "Transitional open-source workbench web app root.",
  "dependencies": {
    "@gaugewright/control-plane-client": "0.0.0",
    "@gaugewright/mobile-web": "0.0.0",
    "@gaugewright/workbench-ui": "0.0.0",
    "@tauri-apps/plugin-dialog": "^2.7.1",
    "solid-js": "^1.9.0"
  },
  "exports": {
    ".": "./src/index.ts",
    "./App": "./src/App.tsx",
    "./main": "./src/main.tsx",
    "./workbench-control-plane": "./src/workbench-control-plane.ts"
  },
  "scripts": {
    "typecheck": "tsc --noEmit -p ../../tsconfig.workbench-web.json",
    "build": "vite build --config vite.config.ts"
  },
  "gaugewright": {
    "artifactKind": "app",
    "ciTarget": "npm run typecheck:workbench-web",
    "dependencyPolicy": {
      "mayDependOn": [
        "open-source"
      ],
      "mustNotDependOn": [
        "source-available-enterprise",
        "private-managed-services"
      ]
    },
    "extractionPhase": "monorepo-transitional",
    "licenseTarget": "Apache-2.0",
    "repoTarget": "open-source",
    "sourcePosture": "open-source"
  }
}
