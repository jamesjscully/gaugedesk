{
  "name": "@gaugewright/gw-embed",
  "version": "0.0.0",
  "private": true,
  "license": "Apache-2.0",
  "type": "module",
  "description": "Transitional open-source public embed client package root.",
  "dependencies": {
    "@gaugewright/control-plane-client": "0.0.0",
    "@gaugewright/workbench-ui": "0.0.0",
    "solid-js": "^1.9.0"
  },
  "exports": {
    ".": "./src/index.ts",
    "./elements": "./src/elements.tsx",
    "./embed-control-plane": "./src/embed-control-plane.ts",
    "./example": "./src/example.ts",
    "./remote-session": "./src/remote-session.ts"
  },
  "scripts": {
    "typecheck": "tsc --noEmit -p ../../tsconfig.embed-client.json",
    "build": "vite build --config ../../vite.embed.config.ts"
  },
  "gaugewright": {
    "artifactKind": "package",
    "ciTarget": "npm run typecheck:embed-client",
    "dependencyPolicy": {
      "mayDependOn": [
        "open-source"
      ],
      "mustNotDependOn": [
        "source-available-enterprise",
        "private-managed-services"
      ]
    },
    "extractionPhase": "monorepo-transitional",
    "licenseTarget": "Apache-2.0",
    "repoTarget": "open-source",
    "sourcePosture": "open-source"
  }
}
